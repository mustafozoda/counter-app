# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
OPENAI_API_KEY=sk-your-key-here

# Model the assistant uses. gpt-4o-mini is fast + cheap; swap anytime.
OPENAI_MODEL=gpt-4o-mini

# Port the API listens on.
PORT=8787

# CORS: "*" is fine for local dev. Lock this down for production.
ALLOWED_ORIGINS=*

# Supabase auth gate (recommended for production). When BOTH are set, /chat
# only answers requests carrying a valid Supabase access token. Leave blank in
# local dev to keep the endpoint open. Values come from Supabase → Settings →
# API (use the same project URL + anon key the app uses).
SUPABASE_URL=
SUPABASE_ANON_KEY=
