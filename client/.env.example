# Copy to `.env.local` (gitignored) and fill in your values.
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the app.

# --- Supabase (real backend: auth + database + storage) ---------------------
# Project URL and anon/public key from: Supabase dashboard → Settings → API.
# The anon key is safe to ship in a client app — Row Level Security protects
# the data. Leave both blank to run the app in local demo mode (no backend).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- AI assistant backend (the FastAPI service in /server) ------------------
#   iOS simulator / web → http://localhost:8787
#   Android emulator     → http://10.0.2.2:8787
#   Physical phone       → http://<your-computer-LAN-ip>:8787  (same Wi-Fi)
#   Production           → https://your-deployed-server.example.com
EXPO_PUBLIC_CHAT_API_URL=http://localhost:8787
