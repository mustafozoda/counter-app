# Copy to `.env.local` (gitignored) and point it at the chat backend in /server.
#
#   iOS simulator / web → http://localhost:8787
#   Android emulator     → http://10.0.2.2:8787
#   Physical phone       → http://<your-computer-LAN-ip>:8787  (same Wi-Fi)
#
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the app.
EXPO_PUBLIC_CHAT_API_URL=http://localhost:8787
